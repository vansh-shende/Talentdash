datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Source {
  CONTRIBUTOR
  SCRAPED
  AI_INFERRED
}

enum Level {
  L3
  L4
  L5
  L6
  SDE_I     @map("SDE-I")
  SDE_II    @map("SDE-II")
  SDE_III   @map("SDE-III")
  Staff
  Principal
  IC4
  IC5
}

model Company {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String   @unique
  slug           String   @unique @map("slug")
  normalizedName String   @unique @map("normalized_name")
  industry       String   @default("Technology")
  headquarters   String   @default("San Francisco, CA")
  foundedYear    Int?     @map("founded_year")
  headcountRange String?  @map("headcount_range")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  salaries       Salary[]

  @@map("companies")
}

model Salary {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId         String   @map("company_id") @db.Uuid
  role              String   @map("role")
  level             Level
  location          String
  currency          String   @default("USD") @db.Char(3)
  experienceYears   Int      @map("experience_years")
  baseSalary        BigInt   @map("base_salary")
  bonus             BigInt   @default(0) @map("bonus")
  stock             BigInt   @default(0) @map("stock")
  totalCompensation BigInt   @map("total_compensation")
  source            Source   @default(CONTRIBUTOR)
  confidenceScore   Decimal  @default(1.0) @map("confidence_score") @db.Decimal(3, 2)
  isVerified        Boolean  @default(false) @map("is_verified")
  submittedAt       DateTime @default(now()) @map("submitted_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, level, location])
  @@index([totalCompensation])
  @@index([submittedAt])
  @@index([location, level])
  @@map("salaries")
}

model ErrorLog {
  id              BigInt   @id @default(autoincrement())
  errorMessage    String   @map("reason")
  errorStack      String?  @map("error_stack")
  endpoint        String?
  payloadSnapshot Json?    @map("payload")
  severity        String   @default("ERROR")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("error_logs")
}
